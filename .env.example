# 本地通知配置模板
# 复制为 .env 后填写，再运行: python scripts/push_accounts_secret.py
#
# 账号配置请使用 .accounts.json（参考 .accounts.json.example）
# api_user 可从 session 自动提取，无需手动填写

# 飞书机器人 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 以下为可选通知渠道，按需取消注释
# DINGDING_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_password
# EMAIL_TO=recipient@example.com
# EMAIL_SENDER=
# CUSTOM_SMTP_SERVER=
# PUSHPLUS_TOKEN=your_pushplus_token
# SERVERPUSHKEY=your_server_pushkey
# WEIXIN_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
# GOTIFY_URL=https://your-gotify-server/message
# GOTIFY_TOKEN=your_gotify_token
# GOTIFY_PRIORITY=9
# BARK_KEY=your_bark_key
# BARK_SERVER=https://api.day.app
# PROVIDERS={"customrouter":{"domain":"https://example.com"}}
